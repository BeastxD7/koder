# Upstream code-oss source — fetched at build time, never committed (thin-fork discipline)
/upstream/

node_modules/
dist/
out/
*.log
.DS_Store
.env

# packaged build output (OS-Build/*.sh|.ps1 produce these at the repo root)
/VSCode-darwin-arm64/
/VSCode-win32-x64/
/VSCode-linux-x64/
*.zip
*.dmg
*.exe
*.deb

# LakshX agent runtime artifacts from dogfooding this repo as a workspace —
# review-mode plan drafts (agent/src/server.ts's savePlan) are local scratch
# saved on every "# Plan" reply, not a curated team history, so they don't
# belong in git. .lakshx/rules.md is deliberately NOT ignored here — it's
# committed project config, the same convention as AGENTS.md/CLAUDE.md.
.lakshx/plans/
.vercel
