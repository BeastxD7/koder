{
  "name": "koder-chat",
  "displayName": "Koder Agent",
  "description": "Koder's agent panel — talks to the Koder Agent Runtime over ACP.",
  "version": "0.0.2",
  "publisher": "koder",
  "license": "MIT",
  "engines": {
    "vscode": "^1.128.0"
  },
  "main": "./extension.js",
  "scripts": {
    "test:unit": "node --test test/*.test.js"
  },
  "activationEvents": [
    "onStartupFinished"
  ],
  "contributes": {
    "viewsContainers": {
      "secondarySidebar": [
        {
          "id": "koder",
          "title": "Koder",
          "icon": "media/koder.svg"
        }
      ]
    },
    "views": {
      "koder": [
        {
          "type": "webview",
          "id": "koder.chatView",
          "name": "Agent",
          "icon": "media/koder.svg"
        }
      ]
    },
    "commands": [
      {
        "command": "koder.openAgent",
        "title": "Koder: Open Agent",
        "icon": "media/koder.svg"
      },
      {
        "command": "koder.newChat",
        "title": "Koder: New Chat",
        "icon": "$(add)"
      },
      {
        "command": "koder.configureProviders",
        "title": "Koder: Configure AI Providers (BYOK)",
        "icon": "$(gear)"
      },
      {
        "command": "koder.openProviderSettings",
        "title": "Koder: Edit Provider Config File (JSON)"
      },
      {
        "command": "koder.openFeedbackLog",
        "title": "Koder: Open Feedback Log"
      },
      {
        "command": "koder.addSelectionToChat",
        "title": "Add to Koder Chat"
      },
      {
        "command": "koder.enableRemoteAccess",
        "title": "Koder: Enable Remote Access (view this chat from your phone)"
      },
      {
        "command": "koder.disableRemoteAccess",
        "title": "Koder: Disable Remote Access"
      }
    ],
    "keybindings": [
      {
        "command": "koder.openAgent",
        "key": "ctrl+l",
        "mac": "cmd+l"
      }
    ],
    "menus": {
      "view/title": [
        {
          "command": "koder.newChat",
          "when": "view == koder.chatView",
          "group": "navigation@1"
        },
        {
          "command": "koder.configureProviders",
          "when": "view == koder.chatView",
          "group": "navigation@2"
        }
      ],
      "editor/title": [
        {
          "command": "koder.openAgent",
          "group": "navigation@100"
        }
      ],
      "editor/context": [
        {
          "command": "koder.addSelectionToChat",
          "group": "koder@1"
        }
      ]
    },
    "configuration": {
      "title": "Koder Agent",
      "properties": {
        "koder.agent.command": {
          "type": "string",
          "default": "",
          "description": "Command to launch the Koder Agent Runtime (ACP over stdio). Empty = auto-detect the bundled runtime."
        }
      }
    }
  }
}
