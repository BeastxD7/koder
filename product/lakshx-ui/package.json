{
  "name": "lakshx-ui",
  "displayName": "LakshX UI",
  "description": "LakshX's visual identity: LakshX Dark theme and modern editor defaults.",
  "version": "0.0.1",
  "publisher": "lakshx",
  "license": "MIT",
  "engines": { "vscode": "^1.128.0" },
  "categories": ["Themes"],
  "contributes": {
    "themes": [
      {
        "label": "LakshX Dark",
        "uiTheme": "vs-dark",
        "path": "./themes/lakshx-dark-color-theme.json"
      }
    ],
    "configurationDefaults": {
      "workbench.colorTheme": "LakshX Dark",
      "workbench.preferredDarkColorTheme": "LakshX Dark",
      "workbench.preferredLightColorTheme": "LakshX Dark",
      "window.autoDetectColorScheme": false,
      "workbench.startupEditor": "none",
      "workbench.list.smoothScrolling": true,
      "workbench.tree.indent": 14,
      "workbench.tree.renderIndentGuides": "onHover",
      "workbench.layoutControl.enabled": true,
      "workbench.productIconTheme": "icons-carbon",
      "workbench.iconTheme": "symbols",
      "breadcrumbs.enabled": false,
      "editor.fontFamily": "'JetBrains Mono', 'SF Mono', Menlo, Monaco, 'Courier New', monospace",
      "editor.fontLigatures": true,
      "editor.fontSize": 13,
      "editor.lineHeight": 1.7,
      "editor.padding.top": 12,
      "editor.smoothScrolling": true,
      "editor.cursorSmoothCaretAnimation": "on",
      "editor.cursorBlinking": "smooth",
      "editor.minimap.enabled": false,
      "editor.scrollBeyondLastLine": false,
      "editor.renderLineHighlight": "none",
      "editor.guides.indentation": false,
      "terminal.integrated.smoothScrolling": true,
      "window.commandCenter": true,
      "chat.disableAIFeatures": true,
      "chat.commandCenter.enabled": false,
      "chat.agent.enabled": false
    }
  }
}
