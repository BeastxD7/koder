  "semanticHighlighting": true,
  "semanticTokenColors": {
    "namespace": "#c8cede",
    "type": "#5cd3e5",
    "class": "#5cd3e5",
    "enum": "#5cd3e5",
    "interface": "#5cd3e5",
    "typeParameter": "#5cd3e5",
    "function": "#7fb2ff",
    "method": "#7fb2ff",
    "decorator": "#a58fff",
    "macro": "#a58fff",
    "variable": "#dde2ee",
    "parameter": "#e8c9a8",
    "property": "#9cc7ff",
    "enumMember": "#ffb454",
    "event": "#9cc7ff",
    "string": "#7cd6c4",
    "keyword": "#b48cff",
    "number": "#ffb454",
    "regexp": "#5cd3e5",
    "operator": "#8a93a8",
    "comment": { "foreground": "#565f73", "italic": true }
  },
  "tokenColors": [
    {
      "scope": ["comment", "punctuation.definition.comment"],
      "settings": { "foreground": "#565f73", "fontStyle": "italic" }
    },
    {
      "scope": ["string", "string.quoted", "punctuation.definition.string"],
      "settings": { "foreground": "#7cd6c4" }
    },
    {
      "scope": ["string.template meta.embedded", "punctuation.definition.template-expression"],
      "settings": { "foreground": "#b48cff" }
    },
    {
      "scope": ["constant.numeric", "constant.language", "constant.character", "constant.other.placeholder"],
      "settings": { "foreground": "#ffb454" }
    },
    {
      "scope": ["keyword", "storage.type", "storage.modifier", "keyword.control"],
      "settings": { "foreground": "#b48cff" }
    },
    {
      "scope": ["keyword.operator", "punctuation.separator", "punctuation.terminator", "punctuation.accessor", "meta.brace"],
      "settings": { "foreground": "#8a93a8" }
    },
    {
      "scope": ["entity.name.function", "support.function", "meta.function-call entity.name.function"],
      "settings": { "foreground": "#7fb2ff" }
    },
    {
      "scope": ["entity.name.type", "entity.name.class", "support.type", "support.class", "entity.other.inherited-class"],
      "settings": { "foreground": "#5cd3e5" }
    },
    {
      "scope": ["variable", "meta.definition.variable.name", "support.variable"],
      "settings": { "foreground": "#dde2ee" }
    },
    {
      "scope": ["variable.parameter", "meta.parameter"],
      "settings": { "foreground": "#e8c9a8" }
    },
    {
      "scope": ["variable.other.property", "variable.other.object.property", "support.variable.property", "meta.object-literal.key"],
      "settings": { "foreground": "#9cc7ff" }
    },
    {
      "scope": ["entity.name.tag"],
      "settings": { "foreground": "#ff7a93" }
    },
    {
      "scope": ["entity.other.attribute-name"],
      "settings": { "foreground": "#c8b6ff", "fontStyle": "italic" }
    },
    {
      "scope": ["support.type.property-name.css", "support.type.property-name"],
      "settings": { "foreground": "#9cc7ff" }
    },
    {
      "scope": ["constant.other.color", "support.constant.color"],
      "settings": { "foreground": "#ffb454" }
    },
    {
      "scope": ["markup.heading", "entity.name.section"],
      "settings": { "foreground": "#a58fff", "fontStyle": "bold" }
    },
    {
      "scope": ["markup.bold"],
      "settings": { "foreground": "#e6e9f0", "fontStyle": "bold" }
    },
    {
      "scope": ["markup.italic"],
      "settings": { "foreground": "#c8b6ff", "fontStyle": "italic" }
    },
    {
      "scope": ["markup.inline.raw", "markup.fenced_code.block"],
      "settings": { "foreground": "#7cd6c4" }
    },
    {
      "scope": ["markup.underline.link", "string.other.link"],
      "settings": { "foreground": "#8f9dff" }
    },
    {
      "scope": ["markup.inserted"],
      "settings": { "foreground": "#4ed8a2" }
    },
    {
      "scope": ["markup.deleted"],
      "settings": { "foreground": "#ff6b81" }
    },
    {
      "scope": ["invalid", "invalid.illegal"],
      "settings": { "foreground": "#ff6b81" }
    },
    {
      "scope": ["punctuation.definition.decorator", "meta.decorator"],
      "settings": { "foreground": "#a58fff" }
    },
    {
      "scope": ["support.type.primitive", "keyword.type"],
      "settings": { "foreground": "#5cd3e5" }
    },
    {
      "scope": ["source.json support.type.property-name"],
      "settings": { "foreground": "#9cc7ff" }
    },
    {
      "scope": ["source.yaml entity.name.tag"],
      "settings": { "foreground": "#9cc7ff" }
    },
    {
      "scope": ["source.shell variable.other"],
      "settings": { "foreground": "#c8b6ff" }
    }
  ]
}
