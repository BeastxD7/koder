{
  "name": "@lakshx/agent",
  "version": "0.0.1",
  "private": true,
  "description": "LakshX Agent Runtime — editor-independent, speaks ACP. Phase 0: ACP client spike driving Claude Code.",
  "type": "module",
  "bin": {
    "lakshx-agent": "./src/server.ts"
  },
  "scripts": {
    "spike": "tsx src/spike.ts",
    "serve": "tsx src/server.ts",
    "test": "tsx src/test-client.ts",
    "test:unit": "npx tsx --test test/*.test.ts",
    "typecheck": "tsc --noEmit",
    "bundle": "esbuild src/server.ts --bundle --platform=node --target=node20 --format=cjs --outfile=../product/koder-chat/agent/server.cjs --log-level=warning"
  },
  "dependencies": {
    "@agentclientprotocol/sdk": "^1.2.1",
    "@zed-industries/claude-code-acp": "^0.16.2",
    "langfuse": "^3.38.20"
  },
  "devDependencies": {
    "@types/node": "^24.0.0",
    "esbuild": "^0.28.1",
    "tsx": "^4.19.0",
    "typescript": "^5.6.0"
  }
}
