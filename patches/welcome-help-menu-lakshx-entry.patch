+// LakshX: real Help-menu replacement for the "Welcome" entry hidden above.
+// The `walkthroughs`/menu contribution points extensions can use
+// (menusExtensionPoint.ts's apiMenus allowlist) do not include
+// MenuId.MenubarHelpMenu, so product/lakshx-welcome's package.json cannot
+// place a Help-menu item on its own — this core-side registration is the
+// only way to put an extension-contributed command (`lakshx.showWelcome`,
+// registered by that extension's extension.js) onto the Help menu. Same
+// group/order slot the stock "Welcome" entry used, since that one is now
+// hidden.
+MenuRegistry.appendMenuItem(MenuId.MenubarHelpMenu, {
+	group: '1_welcome',
+	command: {
+		id: 'lakshx.showWelcome',
+		title: localize2('lakshxWelcome', 'Welcome to LakshX'),
+	},
+	order: 1,
