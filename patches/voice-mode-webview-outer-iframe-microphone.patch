@@ -424,6 +424,22 @@ export class WebviewElement extends Disposable implements IWebviewElement, Webvi
 		if (!isFirefox) {
 			allowRules.push('clipboard-read', 'clipboard-write');
 		}
+		// LakshX: voice mode (docs/research/14-voice-mode.md) — delegate the
+		// microphone permission down into this outer webview iframe. The `*`
+		// (rather than bare `microphone`, which defaults to 'self'/same-origin)
+		// matters: this iframe's content is served from a distinct
+		// `vscode-webview://<origin>` origin, and it nests a second,
+		// same-scheme-but-different-origin iframe (see pre/index.html) that
+		// is where the actual composer JS calling getUserMedia runs. Feature
+		// Policy/Permissions Policy delegation does not cross an origin
+		// boundary without an explicit allowlist, so a same-origin-only
+		// `microphone` here would silently fail deeper in — the symptom is
+		// "microphone is not allowed in this document" even though this line
+		// looks like it granted it. Paired with electron-main/app.ts's
+		// `allowedPermissionsInWebview` (Electron's OS-permission gate, a
+		// separate layer from this HTML Permissions Policy attribute) and
+		// the matching `microphone *` on the inner iframe in pre/index.html.
+		allowRules.push('microphone *');
 		element.setAttribute('allow', allowRules.join('; '));
 
 		element.style.border = 'none';
